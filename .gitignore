# ============================================================
# .gitignore — Financial Intelligence Copilot
# Stack: Python (FastAPI) + React (Vite) + MySQL + FAISS
# ============================================================

# ========================
# Environment & Secrets
# ========================
.env
.env.*
!.env.example

# ========================
# Python
# ========================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/
*.pyo
*.pyd

# Virtual environments
venv/
env/
.venv/
ENV/

# pytest / coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.tox/
.nox/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Jupyter
.ipynb_checkpoints/

# ========================
# Node.js / Frontend
# ========================
node_modules/
dist/
dist-ssr/
build/
*.local
.cache/

# Logs
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Vite
*.vite/

# ESLint
.eslintcache

# ========================
# Uploads & Generated Files
# ========================
backend/uploads/
*.faiss
faiss_index/

# Exported reports
*.xlsx
!backend/*.example.xlsx

# ========================
# Database
# ========================
*.sql.bak
*.dump

# ========================
# IDE & Editor
# ========================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln

# ========================
# OS Files
# ========================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
$RECYCLE.BIN/

# ========================
# Misc
# ========================
*.log
*.bak
*.tmp
*.temp
*.pid
*.seed
*.pid.lock
